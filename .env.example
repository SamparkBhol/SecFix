LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=
LLM_MODEL=qwen2.5-coder:7b
LLM_TEMP=0
LLM_TIMEOUT=120

SECFIX_WORKERS=8
SECFIX_ATTEMPTS=2
SECFIX_MAX_CHARS=12000
SECFIX_VERIFY=1
SECFIX_CACHE=

SECFIX_CONTEXT=0
SECFIX_EMBED_MODEL=nomic-embed-text

# Presets — uncomment one set. The default above is Ollama (local, no key, no signup):
#   install from https://ollama.com then: ollama pull qwen2.5-coder:7b

# Groq (free tier, fast):
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_your_free_key
# LLM_MODEL=llama-3.3-70b-versatile

# OpenRouter (has free models):
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-your_free_key
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Google Gemini (free tier, OpenAI-compatible endpoint):
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_API_KEY=your_free_gemini_key
# LLM_MODEL=gemini-2.0-flash

# OpenAI:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-your_key
# LLM_MODEL=gpt-4o-mini
